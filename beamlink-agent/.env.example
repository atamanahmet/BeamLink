# ── Agent ─────────────────────────────────────────────────────────
# Your display name on the network
AGENT_NAME=MyAgent
# Default 9090. Change if port is already in use.
AGENT_PORT=9090
# Auto-detects LAN IP. Set manually if auto-detection fails.
AGENT_IP=auto

# ── Nexus Connection ──────────────────────────────────────────────
# Full URL of your Nexus server e.g. http://192.168.1.10:7472
AGENT_NEXUS_URL=http://192.168.1.1:7472

# ── UI Credentials ────────────────────────────────────────────────
AGENT_UI_USERNAME=agent
AGENT_UI_PASSWORD=changeme

# ── JWT ───────────────────────────────────────────────────────────
# Leave as "auto", secret is generated and persisted to DB on first launch.
AGENT_JWT_SECRET=auto

# ── Upload Limits ─────────────────────────────────────────────────
# -1 = unlimited, or set with unit e.g. 100MB
MULTIPART_ENABLED=true
MULTIPART_MAX_FILE_SIZE=-1
MULTIPART_MAX_REQUEST_SIZE=-1
MULTIPART_FILE_SIZE_THRESHOLD=0
TRANSFER_EXPIRY_HOURS=24