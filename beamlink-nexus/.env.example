# ── Nexus ─────────────────────────────────────────────────────────
# Display name for this Nexus node
NEXUS_NAME=MyNexus
# Default port is 7472. Change if port is already in use.
NEXUS_PORT=7472
# Auto-detects local IP. Set manually if auto-detection fails.
NEXUS_IP=auto

# ── UI ─────────────────────────────────────────────────────────
# Dev
NEXUS_CORS_STATIC_ORIGINS=http://localhost:5174

# ── Admin ─────────────────────────────────────────────────────────
# Change these before first launch.
NEXUS_ADMIN_USERNAME=admin
NEXUS_ADMIN_PASSWORD=changeme

# ── JWT ───────────────────────────────────────────────────────────
# JWT SECRET (initial bootstrap only)
# Used only on first application startup if no existing database secret exists.
# After initialization, the value stored in the database becomes authoritative.
# Changing this value later will NOT affect an existing installation.
# To reset identity, you must delete the database or use a dedicated reset procedure.
NEXUS_JWT_SECRET=auto
NEXUS_JWT_ADMIN_EXPIRATION_MINUTES=480
NEXUS_JWT_AGENT_AUTH_EXPIRATION_DAYS=90
NEXUS_JWT_AGENT_PUBLIC_EXPIRATION_DAYS=30

# ── Upload Limits ─────────────────────────────────────────────────
MULTIPART_ENABLED=true
MULTIPART_MAX_FILE_SIZE=-1
MULTIPART_MAX_REQUEST_SIZE=-1
MULTIPART_FILE_SIZE_THRESHOLD=0

# ── Transfer ──────────────────────────────────────────────────────
TRANSFER_EXPIRY_HOURS=24